# --- Required ---

# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# For production add: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# URL of your app (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app

# PostgreSQL connection string (get from Neon: https://neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Direct (non-pooled) URL for Prisma migrations — Neon provides both
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Optional (for email notifications) ---
# Leave blank to disable email sending (bookings will still work, logged to console)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_email@gmail.com
EMAIL_SERVER_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
